# =============================================================================
# Environment template for both Docker and manual setup
# Copy to .env and fill in your values.
# =============================================================================

# Timezone for giveaways, timestamps, etc. Use Asia/Jakarta everywhere so times match.
TIMEZONE=Asia/Jakarta

# -----------------------------------------------------------------------------
# Database (MySQL/MariaDB)
# -----------------------------------------------------------------------------
# For Docker: app connects to host "database"; DB_HOST is unused. DB_PORT is
# used for mapping (e.g. 3306:3306).
# For manual: set DB_HOST to your database host (e.g. localhost).
DB_HOST=localhost
DB_PORT=3306
DB_USER=dansday_bot
DB_PASSWORD=change_me
DB_NAME=dansday_bot

# Required for Docker only: MariaDB root password (used by database + phpMyAdmin)
DB_ROOT_PASSWORD=change_me_strong_root_password

# -----------------------------------------------------------------------------
# Control panel
# -----------------------------------------------------------------------------
CONTROL_PANEL_PORT=80
# HOST_PORT=3333
# Generate with: openssl rand -base64 32
SESSION_SECRET=change_me_generate_with_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# Mail (optional, for features that send email)
# -----------------------------------------------------------------------------
MAIL_HOST=xxx.dansday.com
MAIL_PORT=587
MAIL_USERNAME=xxx@dansday.com
MAIL_PASSWORD=password

# -----------------------------------------------------------------------------
# Redis (optional, for session store + rate limiting)
# -----------------------------------------------------------------------------
# Format: redis://default:password@host:port/db
REDIS_URL=redis://default:change_me@localhost:6379/0
