{
	"compilerOptions": {
		"target": "ES2020",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"outDir": "./build-bots",
		"rootDir": "./src/lib/server",
		"strict": false,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowJs": true,
		"noEmitOnError": false,
		"declaration": false,
		"isolatedModules": false
	},
	"include": ["src/lib/server/**/*.ts"]
}
