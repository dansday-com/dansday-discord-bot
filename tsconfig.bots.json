{
	"compilerOptions": {
		"target": "ES2020",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"outDir": "./bots",
		"rootDir": "./src/lib",
		"strict": false,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowJs": true,
		"noEmitOnError": false,
		"declaration": false,
		"isolatedModules": false
	},
	"include": ["src/lib/backend/**/*.ts", "src/lib/utils/**/*.ts", "src/lib/database.ts", "src/lib/drizzle.ts", "src/lib/schema.ts", "src/lib/redis.ts"]
}
