{
	"compilerOptions": {
		"target": "ES2020",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"outDir": "./bots",
		"rootDir": "./src/lib/backend",
		"strict": false,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowJs": true,
		"noEmitOnError": false,
		"declaration": false,
		"isolatedModules": false
	},
	"include": ["src/lib/backend/**/*.ts"]
}
